generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Пользователи системы (авторизация)
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("ADMIN") // "ADMIN" | "DIRECTOR" | "TEACHER"
  teacherId    String?  @unique // связь с Teacher для роли TEACHER
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teacher Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
}

model Teacher {
  id             String   @id @default(uuid())
  lastName       String
  firstName      String
  patronymic     String?
  phone          String?

  // Ставки — базовые
  individualRate      Int      @default(0) // тенге/час за индивидуальное занятие
  groupRate           Int      @default(0) // тенге/час за групповое (базовая, 2 ребёнка)
  groupRate3          Int      @default(0) // ставка за группу из 3 детей
  groupRate5          Int      @default(0) // ставка за группу из 5 детей
  assistantRate       Int      @default(0) // ставка когда работает ассистентом
  accompanimentRate   Int      @default(0) // ставка сопровождения (900-1000₸)
  pairRate            Int      @default(0) // ставка парного занятия
  saturdayRate        Int      @default(0) // субботняя ставка

  // Повышенные ставки по времени суток
  morningBonusRate    Int      @default(0) // доплата за утренние часы (9:00-10:00)
  eveningBonusRate    Int      @default(0) // доплата за вечерние часы (17:00-19:00)

  // Поведенческие
  behavioralBonus     Int      @default(0) // доплата за поведенческого ребёнка (тенге/час)

  room                String?  // кабинет по умолчанию
  specialization      String?  // "И" (интенсив), "А" (академ), etc.
  isMethodist         Boolean  @default(false)
  methodistWeeklyRate Int      @default(0) // недельная ставка методиста (5000₸)
  methodistDailyRate  Int      @default(0) // дневная ставка методиста (авто: weeklyRate / 5)
  isActive            Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  groups           Group[]
  scheduleSlots    ScheduleSlot[]
  substitutions    Attendance[]     @relation("SubstituteTeacher")
  assistantSlots   Attendance[]     @relation("AssistantTeacher")
  methodistChecks  MethodistCheck[]
  user             User?
  freezes          ScheduleFreeze[]
}

model Student {
  id            String   @id @default(uuid())
  lastName      String
  firstName     String
  patronymic    String?
  parentName    String?
  parentPhone   String?
  hourlyRate    Int      @default(0) // стоимость часа для родителя (тенге)
  isBehavioral  Boolean  @default(false) // поведенческий ребёнок (доплата педагогу)
  scheduleType  String?  // "Интенсив", "ПН-СР-ПТ", "ВТ-ЧТ", "Суббота", "МНО рус", "МНО каз"
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  groupMembers  GroupMember[]
  scheduleSlots ScheduleSlot[]
  attendances   Attendance[]
  payments      Payment[]
  freezes       ScheduleFreeze[]
}

model Group {
  id        String   @id @default(uuid())
  name      String // М0, М1, ГРМ1 и т.д.
  groupType String? // "ГРМ", "М0", "М1", "ГР Реч", "ОНР", "АФК", "ЛФК"
  teacherId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher       Teacher        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  members       GroupMember[]
  scheduleSlots ScheduleSlot[]
}

model GroupMember {
  id        String @id @default(uuid())
  groupId   String
  studentId String

  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupId, studentId])
}

model ScheduleSlot {
  id            String @id @default(uuid())
  teacherId     String
  studentId     String? // для индивидуальных занятий
  groupId       String? // для групповых занятий
  dayOfWeek     Int // 1=Пн, 2=Вт, 3=Ср, 4=Чт, 5=Пт, 6=Сб, 7=Вс
  startTime     String // "09:00"
  endTime       String // "10:00"
  weekStartDate  String // "2025-01-20" — понедельник недели
  lessonType     String // "INDIVIDUAL" | "GROUP"
  lessonCategory String? // "А", "И", "Тех", "СОПР", "Метод"
  room           String? // кабинет для этого занятия

  // Отмена / перенос
  isCancelled    Boolean  @default(false)
  cancelReason   String?

  teacher     Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  student     Student?     @relation(fields: [studentId], references: [id], onDelete: SetNull)
  group       Group?       @relation(fields: [groupId], references: [id], onDelete: SetNull)
  attendances Attendance[]
}

// Заморозка расписания (каникулы и т.д.)
model ScheduleFreeze {
  id         String   @id @default(uuid())
  studentId  String?  // null = весь центр
  teacherId  String?  // null = все педагоги
  startDate  String   // "2025-06-01"
  endDate    String   // "2025-06-15"
  reason     String
  createdAt  DateTime @default(now())

  student Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher? @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([startDate, endDate])
}

// Статусы посещаемости:
// ATTENDED — присутствовал (педагог ✅, родитель ✅)
// ABSENT_NO_REASON — без причины (педагог ❌, родитель ✅ штраф)
// ABSENT_VALID_REASON — уважительная причина (педагог ❌, родитель ❌)
// SICK — больничный (педагог ❌, родитель ❌)
// TRANSFERRED — перенос на другую дату (педагог ❌, родитель ❌)
// MAKEUP — отработка (педагог ✅, родитель ✅)
// Legacy: LATE, ABSENT — для старых данных

model Attendance {
  id             String   @id @default(uuid())
  scheduleSlotId String
  studentId      String
  date           String // "2025-01-20"
  status         String   @default("ABSENT_NO_REASON")
  isPresent      Boolean  @default(false) // legacy
  markedAt       DateTime?

  // Замена педагога
  isSubstitution      Boolean  @default(false)
  substituteTeacherId String?

  // Ассистент
  assistantTeacherId  String?

  // Перенос
  transferredToDate   String?  // дата на которую перенесён
  makeupFromDate      String?  // от какой даты отработка

  // Доп. информация
  reason              String?  // причина (для уважительной/переноса)
  note                String?  // комментарий администратора

  scheduleSlot      ScheduleSlot @relation(fields: [scheduleSlotId], references: [id], onDelete: Cascade)
  student           Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  substituteTeacher Teacher?     @relation("SubstituteTeacher", fields: [substituteTeacherId], references: [id], onDelete: SetNull)
  assistantTeacher  Teacher?     @relation("AssistantTeacher", fields: [assistantTeacherId], references: [id], onDelete: SetNull)

  @@unique([scheduleSlotId, studentId, date])
}

// Методический час — ежедневная отметка
model MethodistCheck {
  id        String   @id @default(uuid())
  teacherId String
  date      String   // "2025-01-20"
  completed Boolean  @default(true) // состоялся или нет

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, date])
}

// Оплаты от родителей
model Payment {
  id        String   @id @default(uuid())
  studentId String
  amount    Int      // сумма оплаты (тенге)
  date      String   // "2025-01-20" — дата оплаты
  note      String?  // комментарий
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

// Журнал всех изменений в системе (audit trail)
model AuditLog {
  id         String   @id @default(uuid())
  entityType String   // "Teacher", "Student", "ScheduleSlot", "Attendance", "Payment", etc.
  entityId   String
  action     String   // "CREATE", "UPDATE", "DELETE"
  changes    Json?    // { field: { old: X, new: Y } }
  userId     String?  // null пока нет авторизации
  userName   String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// Псевдонимы для импорта расписания из Google Sheets
model NameAlias {
  id        String   @id @default(uuid())
  alias     String   // как написано в таблице
  type      String   // "student" | "teacher" | "group"
  entityId  String   // UUID сущности в БД
  createdAt DateTime @default(now())

  @@unique([alias, type])
}
